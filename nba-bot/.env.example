# Kalshi API (required)
KALSHI_API_KEY_ID=your-api-key-id
KALSHI_PRIVATE_KEY_PATH=./kalshi-key.pem
KALSHI_ENV=demo  # "demo" or "production"

# BetStack API (primary odds source — free, no monthly cap)
BETSTACK_API_KEY=your-key-here

# The Odds API (optional fallback)
ODDS_API_KEY=your-key-here

# Telegram alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Bot settings
PAPER_TRADING=true
INITIAL_BANKROLL_CENTS=50000  # $500 in cents
LOG_LEVEL=INFO
